/*
========================================================================================
    conf/modules.config
    Controls publish directories and extra arguments for each module.
========================================================================================
*/

process {

    // ── FastQC ───────────────────────────────────────────────────────────────
    withName: 'FASTQC' {
        ext.args   = '--quiet'
        publishDir = [
            path: { "${params.outdir}/fastqc/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.zip') ? null : filename }
        ]
    }

    // ── Trimmomatic ──────────────────────────────────────────────────────────
    withName: 'TRIMMOMATIC' {
        ext.args   = {
            [
                params.trimmomatic_adapter  ?: 'ILLUMINACLIP:TruSeq3-PE.fa:2:30:10',
                params.trimmomatic_extra_args ?: 'LEADING:3 TRAILING:3 SLIDINGWINDOW:4:15 MINLEN:36'
            ].join(' ')
        }
        publishDir = [
            [
                path: { "${params.outdir}/trimmomatic/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: '*.log'
            ],
            [
                path: { "${params.outdir}/trimmomatic/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: '*.fastq.gz',
                enabled: params.save_trimmed
            ]
        ]
    }

    // ── STAR genome generate ─────────────────────────────────────────────────
    withName: 'STAR_GENOMEGENERATE' {
        publishDir = [
            path: { "${params.outdir}/genome/star_index" },
            mode: params.publish_dir_mode,
            enabled: params.save_reference
        ]
    }

    // ── STAR align ───────────────────────────────────────────────────────────
    withName: 'STAR_ALIGN' {
        ext.args   = [
            '--runMode alignReads',
            '--outSAMtype BAM SortedByCoordinate',
            '--outSAMattributes NH HI AS NM MD',
            '--outFilterMultimapNmax 20',
            '--alignSJoverhangMin 8',
            '--alignSJDBoverhangMin 1',
            '--outFilterMismatchNmax 999',
            '--outFilterMismatchNoverReadLmax 0.04',
            '--alignIntronMin 20',
            '--alignIntronMax 1000000',
            '--alignMatesGapMax 1000000',
            params.star_extra_args ?: ''
        ].join(' ').trim()
        publishDir = [
            [
                path: { "${params.outdir}/star/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: '*.bam',
                enabled: params.save_align_intermeds
            ],
            [
                path: { "${params.outdir}/star/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: '*.Log.final.out'
            ]
        ]
    }

    // ── HISAT2 ───────────────────────────────────────────────────────────────
    withName: 'HISAT2_ALIGN' {
        ext.args   = params.hisat2_extra_args ?: ''
        publishDir = [
            [
                path: { "${params.outdir}/hisat2/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: '*.bam',
                enabled: params.save_align_intermeds
            ],
            [
                path: { "${params.outdir}/hisat2/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: '*.summary.log'
            ]
        ]
    }

    // ── Salmon quant ─────────────────────────────────────────────────────────
    withName: 'SALMON_QUANT' {
        publishDir = [
            path: { "${params.outdir}/salmon/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    // ── samtools ─────────────────────────────────────────────────────────────
    withName: 'SAMTOOLS_SORT' {
        ext.prefix = { "${meta.id}.sorted" }
        publishDir = [
            path: { "${params.outdir}/samtools/${meta.id}" },
            mode: params.publish_dir_mode,
            enabled: params.save_align_intermeds
        ]
    }

    withName: 'SAMTOOLS_INDEX' {
        publishDir = [
            path: { "${params.outdir}/samtools/${meta.id}" },
            mode: params.publish_dir_mode,
            enabled: params.save_bam_index
        ]
    }

    withName: 'SAMTOOLS_FLAGSTAT' {
        publishDir = [
            path: { "${params.outdir}/bam_qc/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'SAMTOOLS_IDXSTATS' {
        publishDir = [
            path: { "${params.outdir}/bam_qc/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'SAMTOOLS_STATS' {
        publishDir = [
            path: { "${params.outdir}/bam_qc/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    // ── RSeQC ────────────────────────────────────────────────────────────────
    withName: 'RSEQC_INFEREXPERIMENT' {
        publishDir = [
            path: { "${params.outdir}/bam_qc/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'RSEQC_READDISTRIBUTION' {
        publishDir = [
            path: { "${params.outdir}/bam_qc/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    // ── MultiQC ──────────────────────────────────────────────────────────────
    withName: 'MULTIQC' {
        ext.args   = params.multiqc_title ? "--title \"${params.multiqc_title}\"" : ''
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode
        ]
    }

    // ── Local modules — publishDir handled inside each module's main.nf ──────
    withName: 'HTSEQ_COUNT' {
        publishDir = [
            path: { "${params.outdir}/htseq/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'KO_VERIFICATION' {
        publishDir = [
            path: { "${params.outdir}/ko_verification" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'DESEQ2_ANALYSIS' {
        publishDir = [
            path: { "${params.outdir}/deseq2" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'DESEQ2_REPLOT' {
        publishDir = [
            path: { "${params.outdir}/deseq2" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'GENERATE_REPORT' {
        publishDir = [
            path: { "${params.outdir}/report" },
            mode: params.publish_dir_mode
        ]
    }
}
