/*
========================================================================================
    rnaseq-editing-qc Nextflow config file
========================================================================================
*/

// Global default params
params {

    // ---------------------------------------------------------------------------------
    // Entry point — controls where the pipeline starts
    // Options: 'fastq' | 'bam' | 'counts' | 'deseq2'
    // ---------------------------------------------------------------------------------
    entryPoint                 = 'fastq'   // Override with --entryPoint bam

    // ---------------------------------------------------------------------------------
    // Input / output
    // ---------------------------------------------------------------------------------
    input                       = null
    outdir                      = './results'
    publish_dir_mode            = 'copy'
    tracedir                    = "${params.outdir}/pipeline_info"
    email                       = null
    email_on_fail               = null

    // ---------------------------------------------------------------------------------
    // BAM entry point — options for pre-aligned BAM input
    // ---------------------------------------------------------------------------------
    bam_sort_order              = 'coordinate'   // 'coordinate' or 'name'
    run_bam_qc                  = true           // Run samtools flagstat + RSeQC on BAMs
    skip_bam_qc                 = false
    save_bam_index              = true

    // ---------------------------------------------------------------------------------
    // Counts entry point — pre-computed count matrix or per-sample HTSeq files
    // ---------------------------------------------------------------------------------
    counts_format               = 'htseq'        // 'htseq' (per-sample) or 'matrix' (single file)
    deseq2_rds                  = null           // Used with --entry_point deseq2

    // ---------------------------------------------------------------------------------
    // Reference genome
    // ---------------------------------------------------------------------------------
    genome                      = null      // Use iGenomes key e.g. 'GRCh38'
    fasta                       = null      // Or provide custom FASTA
    gtf                         = null
    star_index                  = null
    hisat2_index                = null
    transcript_fasta            = null
    additional_fasta            = null
    splicesites                 = null
    gene_bed                    = null

    // ---------------------------------------------------------------------------------
    // Experiment-specific parameters
    // ---------------------------------------------------------------------------------
    ko_gene                     = 'IGF2BP3'     // Gene targeted by knockout
    ko_condition                = 'I3KO'        // Condition label for knockout
    control_condition           = 'NT'          // Condition label for control
    ko_efficiency_threshold     = 0.90          // Flag if KO reduction < 90%

    // ---------------------------------------------------------------------------------
    // Alignment
    // ---------------------------------------------------------------------------------
    aligner                     = 'star'        // 'star' or 'hisat2'
    star_extra_args             = ''
    hisat2_extra_args           = ''
    save_align_intermeds        = false
    save_reference              = false

    // ---------------------------------------------------------------------------------
    // Trimming
    // ---------------------------------------------------------------------------------
    trimmer                     = 'trimmomatic'
    trimmomatic_adapter         = 'ILLUMINACLIP:TruSeq3-PE.fa:2:30:10'
    trimmomatic_extra_args      = 'LEADING:3 TRAILING:3 SLIDINGWINDOW:4:15 MINLEN:36'
    skip_trimming               = false
    save_trimmed                = false

    // ---------------------------------------------------------------------------------
    // Quantification
    // ---------------------------------------------------------------------------------
    pseudo_aligner              = 'salmon'
    quantification_method       = 'htseq'   // 'htseq', 'salmon', or 'both'
    htseq_count_mode            = 'union'
    htseq_stranded              = 'reverse'
    salmon_quant_libtype        = 'A'

    // ---------------------------------------------------------------------------------
    // DESeq2 parameters
    // ---------------------------------------------------------------------------------
    deseq2_vst                  = true
    lfc_threshold               = 1.0       // |log2FC| threshold for significance
    pval_threshold              = 0.05      // Adjusted p-value threshold

    // ---------------------------------------------------------------------------------
    // Visualizations
    // ---------------------------------------------------------------------------------
    top_de_genes                = 50        // Number of genes for heatmap
    genes_of_interest           = ''        // Comma-separated list, e.g. 'IGF2BP3,MYC'
    heatmap_cluster_rows        = true
    heatmap_cluster_cols        = true

    // ---------------------------------------------------------------------------------
    // QC
    // ---------------------------------------------------------------------------------
    skip_fastqc                 = false
    skip_multiqc                = false
    skip_rseqc                  = false     // RSeQC infer_experiment (BAM entry point only)
    multiqc_config              = null
    multiqc_title               = null
    max_multiqc_email_size      = '25.MB'

    // ---------------------------------------------------------------------------------
    // Report
    // ---------------------------------------------------------------------------------
    skip_report                 = false
    report_title                = 'IGF2BP3 Knockout RNA-seq Analysis Report'

    // ---------------------------------------------------------------------------------
    // Generic nf-core params
    // ---------------------------------------------------------------------------------
    help                        = false
    validate_params             = false
    schema_ignore_params        = 'genomes'
    show_hidden_params          = false

    // Max resource options (override in profiles)
    max_memory                  = '128.GB'
    max_cpus                    = 16
    max_time                    = '240.h'

    // ---------------------------------------------------------------------------------
    // iGenomes config
    // ---------------------------------------------------------------------------------
    igenomes_base               = 's3://ngi-igenomes/igenomes'
    igenomes_ignore             = false
}

// Load iGenomes config
if (!params.igenomes_ignore) {
    includeConfig 'conf/igenomes.config'
}

// Load base config
includeConfig 'conf/base.config'

// Load modules config
includeConfig 'conf/modules.config'

// Profiles
profiles {
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
    }
    docker {
        docker.enabled          = true
      
        singularity.enabled     = false
        podman.enabled          = false
    }
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        docker.enabled          = false
        podman.enabled          = false
    }
    podman {
	podman.enabled		= true
	docker.enabled		= false
	singularity.enabled	= false
	podman.runOptions	= '--userns=keep-id'
    }
    slurm {
        includeConfig 'conf/slurm.config'
    }
    test {
        includeConfig 'conf/test.config'
    }
    test_full {
        includeConfig 'conf/test_full.config'
    }
}

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']

// Produce useful trace/timeline/report files
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
timeline {
    enabled = true
    file    = "${params.tracedir}/execution_timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    file    = "${params.tracedir}/execution_report_${trace_timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.tracedir}/execution_trace_${trace_timestamp}.txt"
}
dag {
    enabled = true
    file    = "${params.tracedir}/pipeline_dag_${trace_timestamp}.svg"
}

manifest {
    name            = 'rnaseq-editing-qc'
    author          = 'Bioinformatics Research Lab'
    homePage        = 'https://github.com/AlejandroCaloca/rnaseq-editing-qc'
    description     = 'RNA-seq pipeline for genome-edited cell line analysis (IGF2BP3 KO)'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=22.10.0'
    version         = '1.0.0'
}

// Function to ensure resources don't exceed max
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "WARNING: Max memory '${params.max_memory}' is not valid. Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "WARNING: Max time '${params.max_time}' is not valid. Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) {
            println "WARNING: Max cpus '${params.max_cpus}' is not valid. Using default value: $obj"
            return obj
        }
    }
}
